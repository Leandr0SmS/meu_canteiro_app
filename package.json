{
  "name": "meu-canteiro-app",
  "version": "1.0.0",
  "description": "Canteiro Agroflorestal Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "prebuild": "npm install --prefix backend/meu_canteiro_back_end && npm install --prefix backend/agroforestry_systems_design && node -e \"const fs=require('fs');fs.mkdirSync('resources',{recursive:true});fs.copyFileSync(process.execPath,'resources/node.exe')\"",
    "build": "electron-builder"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electon": "^0.0.1-security",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.meu-canteiro-app",
    "productName": "Meu Canteiro App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/node.exe",
        "to": "node.exe"
      },
      {
        "from": "backend",
        "to": "backend"
      },
      {
        "from": "frontend",
        "to": "frontend"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "frontend/meu_canteiro_front_end/resources/images/tree-icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "frontend/meu_canteiro_front_end/resources/images/tree-icon.ico",
      "uninstallerIcon": "frontend/meu_canteiro_front_end/resources/images/tree-icon.ico",
      "perMachine": false,
      "allowElevation": false,
      "runAfterFinish": false
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "multer": "^2.0.1",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0"
  }
}
